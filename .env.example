# KnowledgeMind - credentials template
# -------------------------------------
# Copy this file to .env and fill in your real values:
#     cp .env.example .env
# .env is gitignored, so your real credentials never get committed.
# Values here OVERRIDE config.json (set via the in-app Setup screen).

# Required
GROQ_API_KEY=your_groq_api_key        # free at https://console.groq.com
TAVILY_API_KEY=your_tavily_api_key    # free at https://tavily.com
SLACK_BOT_TOKEN=xoxb-...              # from https://api.slack.com/apps

# Optional (for live Calendar / Gmail integration)
# Path to your Google OAuth client-secrets file (also gitignored).
GOOGLE_CREDENTIALS_PATH=./credentials.json
